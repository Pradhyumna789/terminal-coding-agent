{
  "name": "terminal-coding-agent",
  "version": "0.1.0",
  "description": "A terminal-based AI coding assistant built as a B.Tech CSE capstone project.",
  "type": "module",
  "bin": {
    "terminal-coding-agent": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc && node --test \"dist/**/*.test.js\"",
    "typecheck": "tsc --project tsconfig.typecheck.json"
  },
  "keywords": [
    "cli",
    "typescript",
    "coding-assistant",
    "capstone"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.19.39",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "typescript-language-server": "^5.1.3"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.217.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.217.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.217.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.217.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-logs": "^0.217.0",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.217.0",
    "@opentelemetry/semantic-conventions": "^1.40.0"
  }
}
